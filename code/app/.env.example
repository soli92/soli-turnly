# =============================================================
# Turnly — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to source control.
# =============================================================

# Database (PostgreSQL 16)
# Format: postgres://user:password@host:port/database
DATABASE_URL="postgres://postgres:password@localhost:5432/turnly"

# Auth.js v5 (next-auth)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# Application URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Inngest (background jobs)
# Get from: https://app.inngest.com/settings/keys
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY=""

# Resend (email provider — TSK-009)
# Opzionale: se assente, le email vengono scritte solo in console (dev stub).
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
# Indirizzo mittente verificato su Resend (dominio personalizzato)
RESEND_FROM_EMAIL="noreply@turnly.app"

# Node environment
NODE_ENV="development"
